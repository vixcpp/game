@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(VIX_GAME_WITH_SDL @VIX_GAME_ENABLE_SDL@)
set(VIX_GAME_WITH_SDL_OPENGL @VIX_GAME_ENABLE_SDL_OPENGL@)

find_dependency(vix_error CONFIG REQUIRED)
find_dependency(vix_time CONFIG REQUIRED)
find_dependency(vix_fs CONFIG REQUIRED)
find_dependency(vix_path CONFIG REQUIRED)
find_dependency(vix_json CONFIG REQUIRED)
find_dependency(vix_log CONFIG REQUIRED)
find_dependency(vix_threadpool CONFIG REQUIRED)
find_dependency(async CONFIG REQUIRED)

if (VIX_GAME_WITH_SDL)
  find_dependency(SDL2 REQUIRED)
  find_dependency(SDL2_image REQUIRED)
endif()

if (VIX_GAME_WITH_SDL_OPENGL)
  find_dependency(OpenGL REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/vix_gameTargets.cmake")

check_required_components(vix_game)
